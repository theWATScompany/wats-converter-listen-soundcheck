<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0-windows;net48</TargetFrameworks>
    <AssemblyName>ListenincConverters</AssemblyName>
    <RootNamespace>Virinco.WATS.Converter.Listen</RootNamespace>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <Nullable>disable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Virinco.WATS.Testing" Version="*" />
    <Compile Remove="ConverterTests.cs" />
    <Compile Remove="_legacy_*.cs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Virinco.WATS.Testing" Version="*" />
    <PackageReference Include="Virinco.WATS.ClientAPI" Version="7.*">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Virinco.WATS.Testing" Version="*" />
    <Content Include="Examples\EU\Data logging example 12-01-2021.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Examples\US\WATS18 11-2-2020.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
